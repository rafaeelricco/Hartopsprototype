  },
  "borderRadius": {
    "none": "0px",
    "sm": "calc(0.75rem - 4px)",
    "md": "calc(0.75rem - 2px)",
    "lg": "0.75rem",
    "xl": "calc(0.75rem + 4px)",
    "full": "9999px"
  },
  "borderWidth": {
    "0": "0px",
    "1": "1px",
    "2": "2px",
    "4": "4px"
  },
  "components": {
    "card": {
      "padding": "16px",
      "borderRadius": "12px",
      "border": "1px solid #E2E8F0",
      "background": "#FFFFFF"
    },
    "button": {
      "primary": {
        "background": "#7D152D",
        "text": "#FFFFFF",
        "height": "42px",
        "borderRadius": "6px",
        "fontWeight": 600,
        "fontSize": "0.9375rem"
      },
      "secondary": {
        "background": "#F1F5F9",
        "text": "#0F172A",
        "height": "42px",
        "borderRadius": "6px",
        "fontWeight": 500,
        "fontSize": "0.9375rem"
      },
      "destructive": {
        "background": "#EF4444",
        "text": "#FFFFFF",
        "height": "42px",
        "borderRadius": "6px",
        "fontWeight": 600,
        "fontSize": "0.9375rem"
      }
    },
    "input": {
      "height": "40px",
      "border": "1px solid #E2E8F0",
      "borderRadius": "6px",
      "background": "#FFFFFF",
      "placeholderColor": "#94A3B8",
      "labelFontSize": "0.875rem",
      "labelFontWeight": 500
    },
    "badge": {
      "borderRadius": "9999px",
      "paddingX": "8px",
      "paddingY": "2px",
      "fontSize": "0.6875rem",
      "fontWeight": 600
    },
    "navigation": {
      "active": {
        "background": "#F1F5F9",
        "text": "#7D152D",
        "fontWeight": 600
      },
      "inactive": {
        "text": "#64748B",
        "fontWeight": 500
      }
    }
  },
  "breakpoints": {
    "sm": "640px",
    "md": "768px",
    "lg": "1024px",
    "xl": "1280px",
    "2xl": "1536px"
  },
  "transitions": {
    "duration": {
      "fast": "100ms",
      "normal": "200ms",
      "slow": "300ms",
      "slower": "500ms"
    },
    "easing": {
      "linear": "cubic-bezier(0, 0, 1, 1)",
      "easeIn": "cubic-bezier(0.4, 0, 1, 1)",
      "easeOut": "cubic-bezier(0, 0, 0.2, 1)",
      "easeInOut": "cubic-bezier(0.4, 0, 0.2, 1)",
      "spring": "cubic-bezier(0.34, 1.56, 0.64, 1)"
    }
  },
  "zIndex": {
    "hide": -1,
    "base": 0,
    "raised": 1,
    "dropdown": 1000,
    "sticky": 1100,
    "banner": 1200,
    "overlay": 1300,
    "modal": 1400,
    "popover": 1500,
    "toast": 1700,
    "tooltip": 1800
